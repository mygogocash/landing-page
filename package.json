{
  "name": "gogocash-landing",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "npm install",
    "local": "npm install && next dev",
    "postinstall": "patch-package",
    "clean": "rm -rf .next",
    "dev": "next dev",
    "dev:clean": "npm run clean && npm run dev",
    "dev:webpack": "next dev --webpack",
    "build": "next build",
    "build:webpack": "next build --webpack",
    "build:clean": "npm run clean && npm run build",
    "deploy:firebase": "next build && node scripts/deploy-firebase-hosting.mjs",
    "start": "next start",
    "lint": "eslint .",
    "test": "tsx --test lib/encode-public-path.test.ts",
    "learn:strapi-push": "tsx scripts/push-learn-to-strapi.ts",
    "generate:assets": "node scripts/generate-seo-assets.mjs",
    "lh:mobile": "npx --yes lighthouse http://127.0.0.1:3000/ --only-categories=performance,accessibility,best-practices,seo --preset=mobile --output=html --output-path=./lighthouse-home-mobile.html --quiet"
  },
  "dependencies": {
    "firebase": "^12.11.0",
    "framer-motion": "^12.38.0",
    "next": "^16.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "firebase-tools": "^14.0.0",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.8",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.19.3",
    "typescript": "^5.0.0"
  }
}
