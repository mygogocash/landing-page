{
  "name": "gogocash-landing",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "npm install",
    "local": "npm install && npm run dev",
    "postinstall": "patch-package",
    "clean": "rm -rf .next",
    "dev:local": "bash scripts/dev-local.sh",
    "dev": "npm exec -- next dev --hostname 0.0.0.0 --port 3000",
    "dev:clean": "npm run clean && npm run dev",
    "dev:webpack": "npm exec -- next dev --webpack",
    "build": "npm exec -- next build",
    "build:webpack": "npm exec -- next build --webpack",
    "build:clean": "npm run clean && npm run build",
    "deploy:firebase": "npm run build && node scripts/deploy-firebase-hosting.mjs",
    "start": "npm exec -- next start",
    "lint": "npm exec -- eslint . --ignore-pattern node_modules --ignore-pattern .next --ignore-pattern .node_modules.stalled",
    "test": "npm exec -- tsx --test lib/*.test.ts",
    "typecheck": "npm exec -- tsc --noEmit",
    "verify": "npm run lint && npm run test && npm run typecheck && npm run build",
    "learn:strapi-push": "npm exec -- tsx scripts/push-learn-to-strapi.ts",
    "generate:assets": "node scripts/generate-seo-assets.mjs",
    "lh:mobile": "npx --yes lighthouse http://127.0.0.1:3000/ --only-categories=performance,accessibility,best-practices,seo --preset=mobile --output=html --output-path=./lighthouse-home-mobile.html --quiet"
  },
  "dependencies": {
    "@swc/helpers": "0.5.15",
    "firebase": "^12.11.0",
    "framer-motion": "^12.38.0",
    "next": "^16.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "firebase-tools": "^14.0.0",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.8",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.19.3",
    "typescript": "^5.0.0"
  }
}
