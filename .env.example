# Firebase (client — use NEXT_PUBLIC_*; set in .env.local for dev, host env for production)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Involve Asia Publisher API (Tools → API in publisher dashboard)
# Never commit real secrets. Token is obtained server-side; do not expose the secret to the browser.
INVOLVE_ASIA_API_KEY=general
INVOLVE_ASIA_API_SECRET=

# Optional: paginate offers/all (100 per page). Default 5 pages = up to 500 offers before display cap.
# INVOLVE_ASIA_MAX_OFFER_PAGES=5

# Optional: max brands shown in the partners strip. Default 150.
# INVOLVE_ASIA_MAX_BRANDS_DISPLAY=150

# Strapi (Learn hub — build-time fetch for static export). See lib/strapi-learn.ts for content-type fields.
# STRAPI_URL=https://your-project.strapi.app
# STRAPI_API_TOKEN=your-read-only-api-token
# Push script only (create/update); use a separate full-access token — never NEXT_PUBLIC_*.
# STRAPI_PUSH_TOKEN=
