# Optional — used at `next build` for live partner/category data from Involve Asia.
# Without these, the site uses bundled partner logos and heuristics.
# INVOLVE_ASIA_API_KEY=
# INVOLVE_ASIA_API_SECRET=
# INVOLVE_ASIA_MAX_OFFER_PAGES=5

# Optional — Firebase Web SDK (public; override defaults in lib/app-config.ts).
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
# NEXT_PUBLIC_ANALYTICS_ENABLED=true

# Optional — LINE Tag (LAP). Empty value disables. Overrides default in lib/app-config.ts.
# NEXT_PUBLIC_LINE_TAG_ID=
# NEXT_PUBLIC_LINE_TAG_ENABLED=true

# Optional — PostHog (product analytics). Requires NEXT_PUBLIC_POSTHOG_KEY. Host defaults to US cloud.
# Production proxy examples (see docs/posthog-events.md):
#   Managed proxy: NEXT_PUBLIC_POSTHOG_HOST=https://<subdomain>.yourdomain.com
#   Firebase fn:    NEXT_PUBLIC_POSTHOG_HOST=https://yourdomain.com/w
# When api_host is not us.i / eu.i ingest, set UI host for toolbar/flags (US or EU app):
# NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# NEXT_PUBLIC_POSTHOG_ENABLED=true
